{
  "name": "daily-deals-api",
  "version": "1.0.0",
  "description": "Fastify server that scrapes Guitar Center daily deals and exposes them via JSON API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "fastify",
    "typescript",
    "web-scraping",
    "guitar-center"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "fastify": "^4.25.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^2.0.0",
    "cheerio": "^1.0.0-rc.12",
    "pino": "^8.17.0",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
